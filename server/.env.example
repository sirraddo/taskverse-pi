# ── TaskVerse Pi Server Environment ─────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.

PORT=8000
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/taskverse

# From Pi Developer Portal (pi://develop.pinet.com) → your app → API Key
PI_API_KEY=your_server_api_key_here

# Pi Platform API base. Same URL for mainnet/testnet; network is set per-app
# in the Developer Portal and the SDK sandbox flag.
PI_PLATFORM_API_URL=https://api.minepi.com/v2

# Long random string for signing your own session JWTs
JWT_SECRET=generate_a_long_random_string_here

# Comma-separated list of Pi usernames allowed to access admin endpoints
ADMIN_USERNAMES=your_pi_username

# Auto-approval policy
AUTO_APPROVE_MAX_REWARD=0.25
AUTO_APPROVE_MIN_USER_APPROVALS=3

# Platform fee (0.05 = 5%)
PLATFORM_FEE_RATE=0.05

# Allowed CORS origin (your deployed frontend URL)
CLIENT_ORIGIN=https://your-app-domain.com
